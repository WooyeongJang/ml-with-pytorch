        "# 5.1.2\n",
        "\n",
        "import pandas as pd\n",
        "\n",
        "df_wine = pd.read_csv('https://archive.ics.uci.edu/ml/'\n",
        "                      'machine-learning-databases/wine/wine.data',\n",
        "                      header=None)\n",
        "\n",
        "# UCI 머신 러닝 저장소에서 Wine 데이터셋을 다운로드할 수 없을 때\n",
        "\n",
        "df_wine.columns = ['Class label', 'Alcohol', 'Malic acid', 'Ash',\n",
        "                   'Alcalinity of ash', 'Magnesium', 'Total phenols',\n",
        "                   'Flavanoids', 'Nonflavanoid phenols', 'Proanthocyanins',\n",
        "                   'Color intensity', 'Hue',\n",
        "                   'OD280/OD315 of diluted wines', 'Proline']\n",
        "\n",
        "df_wine.head()"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.model_selection import train_test_split\n",
        "\n",
        "X, y = df_wine.iloc[:, 1:].values, df_wine.iloc[:, 0].values\n",
        "\n",
        "X_train, X_test, y_train, y_test = \\\n",
        "    train_test_split(X, y, test_size=0.3,\n",
        "                     stratify=y,\n",
        "                     random_state=0)"
      ],
      "metadata": {
        "id": "Eho0NfeL0smw"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "# ---------------------------------------------\n",
        "# 1️⃣ 데이터 표준화 전처리\n",
        "# ---------------------------------------------\n",
        "# 목적: 각 feature의 스케일을 맞추기 (평균=0, 분산=1)\n",
        "\n",
        "sc = StandardScaler()\n",
        "X_train_std = sc.fit_transform(X_train)"
      ],
      "metadata": {
        "id": "7NBtyiVv0inr"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ---------------------------------------------\n",
        "# 2️⃣ 공분산 행렬 구성\n",
        "# ---------------------------------------------\n",
        "# 목적: 변수(feature) 간의 관계(퍼짐 정도) 계산\n",
        "# .T를 사용하는 이유:\n",
        "# → np.cov는 \"행 = 변수\"로 보기 때문에 전치 필요\n",
        "\n",
        "cov_mat = np.cov(X_train_std.T)"
      ],
      "metadata": {
        "id": "YcWIV1lf0zkc"
      },
      "execution_count": 5,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ---------------------------------------------\n",
        "# 3️⃣ 공분산 행렬의 고유값 / 고유벡터 계산\n",
        "# ---------------------------------------------\n",
        "# 목적:\n",
        "# → 데이터가 퍼진 방향(고유벡터)과 중요도(고유값) 찾기\n",
        "\n",
        "eigen_vals, eigen_vecs = np.linalg.eig(cov_mat)"
      ],
      "metadata": {
        "id": "pJgDBeWR0l5J"
      },
      "execution_count": 6,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# ---------------------------------------------\n",
        "# 4️⃣ 고유값 내림차순 정렬 및 고유벡터 순위 결정\n",
        "# ---------------------------------------------\n",
        "# 목적:\n",
        "# → 중요한 방향부터 정렬 (큰 고유값 = 중요한 축)\n",
        "\n",
        "# 고유값 내림차순 정렬 인덱스\n",
        "sorted_idx = np.argsort(eigen_vals)[::-1]\n",
        "\n",
        "# 정렬된 고유값\n",
        "eigen_vals_sorted = eigen_vals[sorted_idx]\n",
        "\n",
        "# 정렬된 고유벡터 (열 기준 정렬)\n",
        "eigen_vecs_sorted = eigen_vecs[:, sorted_idx]\n"
      ],
      "metadata": {
        "id": "VARxKsik01gL"
      },
      "execution_count": 7,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
